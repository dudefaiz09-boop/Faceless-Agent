rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Identity-based access: Users can only upload to their own folder
      // and read public assets.
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        userId == request.auth.uid || 
        // Or if user has specific permission in custom claims
        request.auth.token.permissions.manageLibrary == true
      );
    }
  }
}
