rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Safety Net: Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function getClaims() {
      return request.auth.token;
    }

    function hasRole(role) {
      return isSignedIn() && role in getClaims().roles;
    }

    function can(permission) {
      return isSignedIn() && getClaims().permissions[permission] == true;
    }

    function existing() {
      return resource.data;
    }

    function incoming() {
      return request.resource.data;
    }

    function isParentOf(studentId) {
      return request.auth.uid in get(/databases/$(database)/documents/users/$(studentId)).data.linkedParentIds;
    }

    // USERS
    match /users/{userId} {
      allow get: if isSignedIn() && (
        request.auth.uid == userId || 
        can('manageStudents') || 
        can('manageTeachers') ||
        (request.auth.uid in resource.data.linkedParentIds)
      );
      allow list: if can('manageStudents') || can('manageTeachers');
      
      allow update: if isSignedIn() && (
          can('financialOps') || 
          (request.auth.uid == userId && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL']))
      );
    }

    // AUDIT LOGS
    match /auditLogs/{logId} {
      allow read: if can('manageStudents') || can('manageTeachers') || hasRole('principal') || hasRole('staff');
      allow write: if false; // Only server-side via Admin SDK
    }

    // ANNOUNCEMENTS
    match /announcements/{announcementId} {
      allow read: if isSignedIn() && (
        resource.data.targetClasses.hasAny(['all']) || 
        (request.auth.token.classId != null && resource.data.targetClasses.hasAny([request.auth.token.classId])) ||
        hasRole('teacher') || hasRole('principal') || hasRole('staff')
      );
      allow create: if can('manageAnnouncements') && incoming().authorId == request.auth.uid;
      allow update: if can('manageAnnouncements') && existing().authorId == request.auth.uid;
      allow delete: if can('financialOps') || (can('manageAnnouncements') && existing().authorId == request.auth.uid);
    }

    // ASSIGNMENTS
    match /assignments/{assignmentId} {
      allow read: if isSignedIn();
      allow create: if can('manageAssignments') && incoming().createdBy == request.auth.uid;
      allow update, delete: if can('manageAssignments') && existing().createdBy == request.auth.uid;
    }

    match /submissions/{submissionId} {
      allow read: if isSignedIn() && (
        existing().studentId == request.auth.uid || 
        isParentOf(existing().studentId) ||
        can('manageAssignments')
      );
      allow create: if hasRole('student') && incoming().studentId == request.auth.uid;
      allow update: if (existing().studentId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['content', 'fileUrl'])) ||
                     can('manageAssignments');
    }

    // ATTENDANCE
    match /attendance/{attendanceId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.studentId || 
        isParentOf(resource.data.studentId) ||
        hasRole('teacher') || hasRole('principal') || hasRole('staff') ||
        can('manageAttendance')
      );
      allow write: if can('manageAttendance');
    }

    // FEES
    match /fees/{feeId} {
      allow read: if isSignedIn() && (
        existing().studentId == request.auth.uid || 
        isParentOf(existing().studentId) ||
        can('manageFees')
      );
      allow write: if can('manageFees');
    }

    match /payments/{paymentId} {
      allow read: if isSignedIn() && (
        existing().studentId == request.auth.uid || 
        isParentOf(existing().studentId) ||
        can('manageFees')
      );
      allow create: if isSignedIn() && incoming().studentId == request.auth.uid;
      allow update, delete: if false; // Payments are immutable
    }

    // LIBRARY
    match /library/{resourceId} {
      allow read: if isSignedIn();
      allow write: if can('manageLibrary');
    }

    match /borrowRecords/{recordId} {
      allow read: if isSignedIn() && (
        existing().studentId == request.auth.uid || 
        isParentOf(existing().studentId) ||
        can('manageLibrary')
      );
      allow create: if hasRole('student') && incoming().studentId == request.auth.uid;
      allow update: if can('manageLibrary');
    }

    // PERFORMANCE
    match /performance/{recordId} {
      allow read: if isSignedIn() && (
        existing().studentId == request.auth.uid || 
        isParentOf(existing().studentId) ||
        can('managePerformance')
      );
      allow write: if can('managePerformance');
    }

    match /aiSuggestions/{suggestionId} {
      allow read: if isSignedIn() && (
        existing().studentId == request.auth.uid || 
        isParentOf(existing().studentId) ||
        can('managePerformance')
      );
      allow write: if can('managePerformance');
    }

    match /chatbotLogs/{logId} {
      allow read: if isSignedIn() && (existing().userId == request.auth.uid || can('manageStudents'));
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && existing().userId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['feedback', 'feedbackAt']);
    }

    // CHAT
    match /conversations/{conversationId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn() && request.auth.uid in incoming().participants;
      allow update: if isSignedIn() && request.auth.uid in existing().participants;

      match /messages/{messageId} {
        allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
        allow write: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants && incoming().senderId == request.auth.uid;
      }
    }
  }
}
