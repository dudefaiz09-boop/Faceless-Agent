rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Safety Net: Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function getClaims() {
      return request.auth.token;
    }

    function hasRole(role) {
      return isSignedIn() && role in getClaims().roles;
    }

    function can(permission) {
      return isSignedIn() && getClaims().permissions[permission] == true;
    }

    function existing() {
      return resource.data;
    }

    function incoming() {
      return request.resource.data;
    }

    // USERS
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || can('manageStudents') || can('manageTeachers'));
      allow list: if can('manageStudents') || can('manageTeachers');
      
      allow update: if isSignedIn() && (
          can('financialOps') || 
          (request.auth.uid == userId && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL']))
      );
    }

    // ANNOUNCEMENTS
    match /announcements/{announcementId} {
      allow read: if isSignedIn() && (
        resource.data.targetClasses.hasAny(['all']) || 
        (request.auth.token.classId != null && resource.data.targetClasses.hasAny([request.auth.token.classId])) ||
        hasRole('teacher') || hasRole('principal') || hasRole('staff')
      );
      allow create: if can('manageAnnouncements');
      allow update: if can('manageAnnouncements') && resource.data.authorId == request.auth.uid;
      allow delete: if can('financialOps') || (can('manageAnnouncements') && resource.data.authorId == request.auth.uid);
    }

    // ASSIGNMENTS
    match /assignments/{assignmentId} {
      allow read: if isSignedIn();
      allow create: if can('manageAssignments');
      allow update, delete: if can('manageAssignments') && resource.data.createdBy == request.auth.uid;
    }

    match /submissions/{submissionId} {
      allow read: if isSignedIn() && (
        resource.data.studentId == request.auth.uid || 
        can('manageAssignments')
      );
      allow create: if hasRole('student');
      allow update: if (resource.data.studentId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['content', 'fileUrl'])) ||
                     can('manageAssignments');
    }

    // ATTENDANCE
    match /attendance/{attendanceId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.studentId || 
        hasRole('teacher') || hasRole('principal') || hasRole('staff') ||
        can('manageAttendance')
      );
      allow write: if can('manageAttendance');
    }

    // CHAT
    match /conversations/{conversationId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && request.auth.uid in resource.data.participants;

      match /messages/{messageId} {
        allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
        allow write: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
      }
    }

    // TEST CONNECTION
    match /test/connection {
      allow read: if true;
    }
  }
}
