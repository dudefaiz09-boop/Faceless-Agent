# Supabase project config.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_UPLOADS_BUCKET=educonnect-uploads
CORS_ORIGINS=http://localhost:5173,https://your-web-project.vercel.app

# Web API endpoint. Use /api locally and your Vercel API URL in production.
VITE_API_BASE_URL=/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_SUPABASE_UPLOADS_BUCKET=educonnect-uploads
VITE_DEMO_MODE=false
VITE_ENVIRONMENT=development

# UI/UX QA local config.
# Use dedicated test users only. Do not use production staff/student accounts.
PLAYWRIGHT_BASE_URL=http://127.0.0.1:4173
PLAYWRIGHT_WEB_SERVER_COMMAND=pnpm --filter @educonnect/web build && pnpm --filter @educonnect/web preview --host 127.0.0.1 --port 4173
WEB_QA_DEFAULT_ROLE=admin
WEB_QA_EMAIL=qa-admin@example.com
WEB_QA_PASSWORD=replace-with-local-test-password
WEB_QA_ADMIN_EMAIL=qa-admin@example.com
WEB_QA_ADMIN_PASSWORD=replace-with-local-test-password
WEB_QA_PRINCIPAL_EMAIL=qa-principal@example.com
WEB_QA_PRINCIPAL_PASSWORD=replace-with-local-test-password
WEB_QA_TEACHER_EMAIL=qa-teacher@example.com
WEB_QA_TEACHER_PASSWORD=replace-with-local-test-password
WEB_QA_STUDENT_EMAIL=qa-student@example.com
WEB_QA_STUDENT_PASSWORD=replace-with-local-test-password
WEB_QA_PARENT_EMAIL=qa-parent@example.com
WEB_QA_PARENT_PASSWORD=replace-with-local-test-password
WEB_QA_LIBRARIAN_EMAIL=qa-librarian@example.com
WEB_QA_LIBRARIAN_PASSWORD=replace-with-local-test-password
WEB_QA_ACCOUNTANT_EMAIL=qa-accountant@example.com
WEB_QA_ACCOUNTANT_PASSWORD=replace-with-local-test-password
WEB_QA_STAFF_EMAIL=qa-staff@example.com
WEB_QA_STAFF_PASSWORD=replace-with-local-test-password
PERCY_TOKEN=
QA_FULL_VISUAL=false

# Mobile APK public config. These are bundled into apps/mobile; never use service-role keys.
API_BASE_URL=https://your-api-project.vercel.app/api
# Mobile also accepts VITE_API_BASE_URL, VITE_SUPABASE_URL, and VITE_SUPABASE_ANON_KEY aliases.

# Optional API smoke workflow config.
# API_BASE_URL is also used by .github/workflows/api-smoke.yml and must end with /api.
SMOKE_TENANT_ID=tenant-a
# Use a short-lived low-privilege demo/test user token only. Do not use service-role keys.
SMOKE_ACCESS_TOKEN=

# Optional AI feature key.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
