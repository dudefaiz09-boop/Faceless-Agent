# Supabase project config.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_UPLOADS_BUCKET=educonnect-uploads
CORS_ORIGINS=http://localhost:5173,https://your-web-project.vercel.app

# Web API endpoint. Use /api locally and your Vercel API URL in production.
VITE_API_BASE_URL=/api

# Mobile APK public config. These are bundled into apps/mobile; never use service-role keys.
API_BASE_URL=https://your-api-project.vercel.app/api
# Mobile also accepts VITE_API_BASE_URL, VITE_SUPABASE_URL, and VITE_SUPABASE_ANON_KEY aliases.

# Optional AI feature key.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
