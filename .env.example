# Supabase project config.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_UPLOADS_BUCKET=educonnect-uploads
CORS_ORIGINS=http://localhost:5173,https://your-web-project.vercel.app

# Web API endpoint. Use /api locally and your Vercel API URL in production.
VITE_API_BASE_URL=/api

# Optional AI feature key.
# IMPORTANT: Only OpenRouter free model slugs (ending in :free) are supported.
# If a paid or invalid model is configured, the API will fallback to a prioritized list of free models.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-3-4b-it:free
