# App
APP_NAME=ViralReelAgent
APP_VERSION=0.1.0
DEBUG=false
DEFAULT_TIMEZONE=UTC
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/viralreel

# Redis
REDIS_URL=redis://localhost:6379/0

# Storage (S3-compatible)
STORAGE_BUCKET=viralreel-storage
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_ENDPOINT=

# YouTube API
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:8000/api/v1/auth/youtube/callback

# Instagram / Meta Graph API
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# LLM: Open-source (Ollama) — default
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# LLM: OpenAI — optional fallback
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# TTS Provider: edge, elevenlabs, gtts
TTS_PROVIDER=edge
ELEVENLABS_API_KEY=

# Stock media API keys (optional)
PEXELS_API_KEY=
PIXABAY_API_KEY=
IMAGE_PROVIDER_API_KEY=
VIDEO_PROVIDER_API_KEY=
MUSIC_PROVIDER_API_KEY=

# JWT
JWT_SECRET_KEY=change-me-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=30

# Content settings
HUMAN_REVIEW_REQUIRED=true
CONTENT_MODE=semi-auto
MAX_POSTS_PER_DAY_YOUTUBE=3
MAX_POSTS_PER_DAY_INSTAGRAM=3
MIN_QUALITY_SCORE=80
MIN_COMPLIANCE_SCORE=95

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Video Rendering
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
OUTPUT_DIR=output
TEMP_DIR=tmp
DEFAULT_TTS_VOICE=en-US-JennyNeural
VIDEO_OUTPUT_WIDTH=1080
VIDEO_OUTPUT_HEIGHT=1920
VIDEO_OUTPUT_FPS=30
VIDEO_OUTPUT_BITRATE=8M
CAPTION_FONT_SIZE=48
USE_STOCK_FOOTAGE=false
