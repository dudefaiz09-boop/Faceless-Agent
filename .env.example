# Supabase project config.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_UPLOADS_BUCKET=educonnect-uploads
CORS_ORIGINS=http://localhost:5173,https://your-web-app.pages.dev

# Web API endpoint. Use /api when proxied by Cloudflare Pages.
VITE_API_BASE_URL=/api

# Optional AI feature key.
GEMINI_API_KEY=your_gemini_api_key_if_using_ai
