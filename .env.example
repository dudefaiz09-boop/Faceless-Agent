# App
APP_NAME=ViralReelAgent
APP_VERSION=0.1.0
DEBUG=false
DEFAULT_TIMEZONE=UTC
LOG_LEVEL=INFO
CORS_ORIGINS=https://your-dashboard.vercel.app

# Database: Supabase Free Postgres
DATABASE_URL=postgresql+asyncpg://postgres:<SUPABASE_DB_PASSWORD>@aws-0-your-region.pooler.supabase.com:6543/postgres

# Redis: Upstash Redis Free
REDIS_URL=rediss://default:<UPSTASH_REDIS_PASSWORD>@your-upstash-host.upstash.io:6379

# Storage: optional Supabase Storage S3-compatible settings
STORAGE_BUCKET=faceless-agent
STORAGE_ACCESS_KEY=<SUPABASE_STORAGE_ACCESS_KEY>
STORAGE_SECRET_KEY=<SUPABASE_STORAGE_SECRET_KEY>
STORAGE_ENDPOINT=https://<SUPABASE_PROJECT_REF>.supabase.co/storage/v1/s3

# YouTube API
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=https://your-huggingface-space.hf.space/api/v1/auth/youtube/callback

# Instagram / Meta Graph API
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# LLM: OpenAI-compatible providers such as Groq, OpenRouter, or OpenAI
OPENAI_API_KEY=<PROVIDER_API_KEY>
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# LLM: local Ollama fallback when OPENAI_API_KEY is blank
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# TTS Provider: edge, elevenlabs, gtts
TTS_PROVIDER=edge
ELEVENLABS_API_KEY=

# Stock media API keys (optional)
PEXELS_API_KEY=
PIXABAY_API_KEY=
IMAGE_PROVIDER_API_KEY=
VIDEO_PROVIDER_API_KEY=
MUSIC_PROVIDER_API_KEY=

# JWT
JWT_SECRET_KEY=<GENERATE_A_RANDOM_SECRET>
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=30

# Content settings: conservative defaults for free tiers
HUMAN_REVIEW_REQUIRED=true
CONTENT_MODE=semi-auto
MAX_POSTS_PER_DAY_YOUTUBE=1
MAX_POSTS_PER_DAY_INSTAGRAM=1
MIN_QUALITY_SCORE=80
MIN_COMPLIANCE_SCORE=95

# Celery
CELERY_BROKER_URL=rediss://default:<UPSTASH_REDIS_PASSWORD>@your-upstash-host.upstash.io:6379
CELERY_RESULT_BACKEND=rediss://default:<UPSTASH_REDIS_PASSWORD>@your-upstash-host.upstash.io:6379

# Video Rendering
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
OUTPUT_DIR=output
TEMP_DIR=tmp
DEFAULT_TTS_VOICE=en-US-JennyNeural
VIDEO_OUTPUT_WIDTH=1080
VIDEO_OUTPUT_HEIGHT=1920
VIDEO_OUTPUT_FPS=24
VIDEO_OUTPUT_BITRATE=3M
CAPTION_FONT_SIZE=48
USE_STOCK_FOOTAGE=false
