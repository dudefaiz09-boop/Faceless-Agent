# Mobile Application Environment Configuration
# Export these before running APK builds, or add them as GitHub Secrets/Variables.
# These values are public mobile config. Never put SUPABASE_SERVICE_ROLE_KEY here.

# API Connection
# The base URL pointing to the deployed backend API. Do not use localhost for APK artifacts.
API_BASE_URL=https://your-api-project.vercel.app/api
VITE_API_BASE_URL=https://your-api-project.vercel.app/api

# Supabase Connection
# Provide your actual Supabase URL and anon key so the app can authenticate users.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
