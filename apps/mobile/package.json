{
  "name": "mobile",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "EduConnect Mobile App",
  "main": "index.js",
  "scripts": {
    "start": "react-native start",
    "test": "jest --config jest.config.cjs --runInBand",
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "prebuild:android": "pnpm --dir ../.. --filter @educonnect/shared-api... build",
    "build:android": "node scripts/run-gradle.mjs assembleDebug",
    "build:android:debug": "node scripts/run-gradle.mjs assembleDebug",
    "build:android:release": "node scripts/run-gradle.mjs assembleRelease bundleRelease",
    "verify:android-apk": "node scripts/verify-android-apk.mjs"
  },
  "dependencies": {
    "@educonnect/shared": "workspace:*",
    "@educonnect/shared-api": "workspace:*",
    "@react-native-async-storage/async-storage": "^1.24.0",
    "@supabase/supabase-js": "^2.87.1",
    "@tanstack/react-query": "^5.100.9",
    "react": "18.3.1",
    "react-native": "0.76.3",
    "react-native-url-polyfill": "^2.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "15.0.1",
    "@react-native/babel-preset": "0.76.3",
    "@react-native/eslint-config": "0.76.3",
    "@react-native/gradle-plugin": "0.76.3",
    "@react-native/metro-config": "0.76.3",
    "@react-native/typescript-config": "0.76.3",
    "@types/react": "^18.3.1",
    "@types/react-test-renderer": "^18.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "babel-jest": "^29.6.3",
    "babel-plugin-transform-inline-environment-variables": "^0.4.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-native": "^5.0.0",
    "globals": "^17.6.0",
    "jest": "^29.6.3",
    "prettier": "^3.8.3",
    "react-test-renderer": "18.3.1",
    "typescript": "~5.8.2"
  },
  "engines": {
    "node": ">=18"
  }
}
