# EduConnect mobile public build configuration.
# Copy to apps/mobile/.env for local builds. These values are bundled into the APK.
# Never put SUPABASE_SERVICE_ROLE_KEY or any secret backend key in this file.

API_BASE_URL=https://your-api-project.vercel.app/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key

# Migration aliases are supported by the React Native Babel build:
# VITE_API_BASE_URL=https://your-api-project.vercel.app/api
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
