{
  "name": "functions",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node22 --outfile=dist/index.js --format=esm --external:firebase-admin --external:firebase-functions --external:compression --external:cors --external:express --external:helmet --external:express-rate-limit --external:pino --external:pino-http --external:zod --external:dotenv --external:@google/genai && esbuild src/standalone.ts --bundle --platform=node --target=node22 --outfile=dist/standalone.js --format=esm --external:firebase-admin --external:firebase-functions --external:compression --external:cors --external:express --external:helmet --external:express-rate-limit --external:pino --external:pino-http --external:zod --external:dotenv --external:@google/genai",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "test": "echo 'No tests yet' && exit 0",
    "logs": "firebase functions:log"
  },
  "dependencies": {
    "@google/genai": "^2.0.1",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.1",
    "firebase-admin": "^13.9.0",
    "firebase-functions": "^6.3.2",
    "helmet": "^8.1.0",
    "pino-http": "^11.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@educonnect/logger": "workspace:*",
    "@educonnect/types": "workspace:*",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.2",
    "esbuild": "^0.28.0",
    "firebase-functions-test": "^3.4.0",
    "typescript": "^5.8.2"
  }
}
