# EduConnect Functions Environment Variables
# Store production values as secrets in your hosting provider.
# Copy this file to apps/functions/.env for local development.

# Node environment
NODE_ENV=development
PORT=8080

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_UPLOADS_BUCKET=educonnect-uploads
CORS_ORIGINS=http://localhost:5173,https://your-web-project.vercel.app

# ---------------------------------------------------------------------------
# File Storage — Firebase Storage (new uploads)
# ---------------------------------------------------------------------------
# STORAGE_PROVIDER controls where NEW file uploads go.
# Set to "firebase" to route new uploads to Firebase Storage.
# Set to "supabase" only for legacy backward-compat (not recommended for new deployments).
STORAGE_PROVIDER=firebase

# Firebase service account credentials (BACKEND ONLY — never expose to frontend).
# Create a Firebase project → Storage → Service Account → Generate new private key.
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Paste the private key value exactly. Newlines must be encoded as \n (backslash-n).
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=your-firebase-project.appspot.com

# Signed URL TTL in seconds (default: 900 = 15 minutes).
FIREBASE_SIGNED_URL_TTL_SECONDS=900

# Maximum file upload size in bytes (default: 52428800 = 50 MB).
MAX_UPLOAD_BYTES=52428800

# Public app URL used by AI provider request metadata and links
PUBLIC_APP_URL=https://your-web-project.vercel.app

# AI provider selection
# auto       = OpenRouter free-first, then Gemini fallback
# openrouter = OpenRouter first, then Gemini fallback
# gemini     = Gemini first, then OpenRouter fallback
# offline    = deterministic offline/demo responses only
AI_PROVIDER=auto

# Required for live web AI unless GEMINI_API_KEY is set.
# If both OPENROUTER_API_KEY and GEMINI_API_KEY are missing and AI_PROVIDER is
# not offline, /api/ai/query and /api/ai/context-query return AI_NOT_CONFIGURED
# so the web chatbot can show a setup/unavailable message instead of a blank
# response or generic 500.
# Only approved free OpenRouter models are accepted by the backend.
OPENROUTER_API_KEY=your_openrouter_key_if_using_ai
OPENROUTER_MODEL=google/gemma-3-4b-it:free

# Required for live web AI unless OPENROUTER_API_KEY is set.
GEMINI_API_KEY=your_gemini_api_key_if_using_ai
GEMINI_MODEL=gemini-2.5-flash

# Application configuration
CURRENCY=INR
