# EduConnect Functions Environment Variables
# Use Secret Manager for sensitive production keys

# NODE Environment
NODE_ENV=development # development | production | test
PORT=8080

# GCP / Vertex AI
PROJECT_ID=your_gcp_project_id
VERTEX_LOCATION=us-central1

# AI Secrets (DO NOT COMMIT ACTUAL KEYS)
# In production, these are managed via Cloud Secret Manager
GEMINI_API_KEY=your_gemini_api_key_if_not_using_vertex
