# EduConnect Web Environment Variables
# Copy this to .env.local for development.

# Supabase client configuration (safe for frontend exposure)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_SUPABASE_UPLOADS_BUCKET=educonnect-uploads

# API Configuration.
# Local Vite dev may use /api because apps/web/vite.config.ts proxies to http://localhost:3000.
# Production Vercel web deployments that use the separate API project must use the absolute
# API URL ending in /api, for example:
# VITE_API_BASE_URL=https://educonnect-api-sigma.vercel.app/api
VITE_API_BASE_URL=/api

# Feature Gating
VITE_ENABLE_AI_FEATURES=true
VITE_ENVIRONMENT=development
VITE_DEMO_MODE=false
