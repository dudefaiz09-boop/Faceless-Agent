{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@educonnect/logger": ["../../packages/logger/src/index.ts"],
      "@educonnect/types": ["../../packages/types/src/index.ts"],
      "@educonnect/shared": ["../../packages/shared/src/index.ts"],
      "@educonnect/shared-education": ["../../packages/shared-education/src/index.ts"],
      "@educonnect/shared-analytics": ["../../packages/shared-analytics/src/index.ts"],
      "@educonnect/shared-api": ["../../packages/shared-api/src/index.ts"],
      "@educonnect/shared-notifications": ["../../packages/shared-notifications/src/index.ts"]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": true,
    "noImplicitAny": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
