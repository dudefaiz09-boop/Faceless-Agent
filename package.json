{
  "name": "educonnect-monorepo",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "description": "EduConnect Enterprise Monorepo",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "turbo test && jest",
    "test:e2e": "pnpm dlx --package=@playwright/test@1.56.1 --package=@axe-core/playwright@4.10.2 playwright test -c playwright.config.ts --grep-invert @visual",
    "test:e2e:ui": "pnpm dlx --package=@playwright/test@1.56.1 --package=@axe-core/playwright@4.10.2 playwright test -c playwright.config.ts --ui",
    "test:a11y": "pnpm dlx --package=@playwright/test@1.56.1 --package=@axe-core/playwright@4.10.2 playwright test -c playwright.config.ts qa/e2e/a11y.spec.ts",
    "test:visual": "pnpm dlx --package=@playwright/test@1.56.1 --package=@percy/cli@1.31.3 --package=@percy/playwright@1.0.11 percy exec -- playwright test -c playwright.config.ts qa/e2e/visual.percy.spec.ts",
    "lhci": "pnpm dlx @lhci/cli@0.15.1 autorun --config=./lighthouserc.cjs",
    "qa:ui": "pnpm test:e2e && pnpm lhci",
    "qa:ui:install": "pnpm dlx --package=@playwright/test@1.56.1 playwright install --with-deps chromium",
    "verify": "bash scripts/verify-all.sh",
    "validate:android:win": "powershell -ExecutionPolicy Bypass -File scripts/check-android-env.ps1",
    "validate:release": "bash scripts/validate-release.sh",
    "validate:release:win": "powershell -ExecutionPolicy Bypass -File scripts/validate-release.ps1",
    "smoke:web-api": "tsx scripts/smoke-web-api.ts",
    "demo:api-smoke": "corepack pnpm --filter @educonnect/functions demo:api-smoke",
    "qa:web-matrix": "tsx scripts/export-web-qa-matrix.ts",
    "release:checklist": "tsx scripts/export-release-checklist.ts",
    "audit:web-shared-api": "tsx scripts/audit-web-shared-api-boundaries.ts",
    "build:web": "corepack pnpm --filter @educonnect/web build",
    "build:api": "corepack pnpm --filter @educonnect/functions build",
    "test:mobile": "corepack pnpm --filter mobile test",
    "lint:mobile": "corepack pnpm --filter mobile lint",
    "build:mobile:android": "corepack pnpm --filter mobile build:android",
    "deploy": "corepack pnpm deploy:web",
    "deploy:web": "corepack pnpm --filter @educonnect/web... build",
    "deploy:api": "corepack pnpm --filter @educonnect/functions build",
    "deploy:functions": "corepack pnpm --filter @educonnect/functions build",
    "seed:supabase": "corepack pnpm --filter @educonnect/functions seed:supabase",
    "setup": "corepack pnpm install"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@google/genai": "^2.0.1",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "jest": "^29.7.0",
    "prettier": "3.8.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "turbo": "^2.4.4",
    "typescript": "~5.8.2"
  },
  "packageManager": "pnpm@11.1.0",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "esbuild": "^0.20.2"
  }
}
